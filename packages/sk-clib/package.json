{
	"name": "sk-clib",
	"version": "1.19.0",
	"repository": {
		"type": "git",
		"url": "https://github.com/TreltaSev/sk-clib"
	},
	"type": "module",
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*",
		"dist/styles.css"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js"
		},
		"./ui": {
			"types": "./dist/ui/index.d.ts",
			"svelte": "./dist/ui/index.js"
		},
		"./style": {
			"default": "./dist/styles.css"
		},
		"./theme": {
			"types": "./dist/theme/index.d.ts",
			"svelte": "./dist/theme/index.js",
			"default": "./dist/theme/index.js"
		},
		"./theme/types": {
			"types": "./dist/theme/types.d.ts",
			"default": "./dist/theme/types.js"
		}
	},
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"sideEffects": [
		"**/*.css"
	],
	"keywords": [
		"svelte",
		"component",
		"library"
	],
	"scripts": {
		"dev": "vite dev",
		"build": "svelte-package && node ../../scripts/postbuild-theme-types.mjs && npm run css_build",
		"css_build": "npx tailwindcss -i ./src/library.css -o ./dist/styles.css",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write ."
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.4",
		"@eslint/js": "^10.0.1",
		"@iconify/json": "^2.2.480",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/node": "^22",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"unplugin-icons": "^23.0.1",
		"vite": "^8.0.7"
	},
	"dependencies": {
		"@material/material-color-utilities": "^0.3.0",
		"@sveltejs/package": "^2.5.7",
		"js-cookie": "^3.0.5",
		"tailwind-merge": "^3.2.0",
		"@sveltejs/kit": "^2.57.0",
		"@tailwindcss/cli": "^4.1.5",
		"@tailwindcss/vite": "^4.1.7",
		"tailwindcss": "^4.2.2"
	}
}
